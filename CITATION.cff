message: "If you use the FLUXNET Data Explorer, please cite the versioned software release."
title: "FLUXNET Data Explorer"
type: software
authors:
  - family-names: "Keenan"
    given-names: "Trevor F."
    affiliation: "University of California, Berkeley"
repository-code: "https://github.com/trevorkeenan/fluxnet-data-explorer"
